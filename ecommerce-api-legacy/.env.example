# Copy to .env and provide real values in your environment.
# Never commit real secrets. All values below are safe placeholders/defaults.

PORT=3000

# Database: ':memory:' (default, seeded on boot) or a file path for persistence.
DB_FILE=:memory:
DB_USER=app_user
DB_PASSWORD=

# Payment gateway API key (mock gateway in this demo).
PAYMENT_GATEWAY_KEY=dev-placeholder-key

# SMTP sender.
SMTP_USER=no-reply@example.com

# Bearer token required to access admin/destructive routes.
ADMIN_TOKEN=dev-admin-token

# Password used only to seed the demo user (hashed on boot).
SEED_USER_PASSWORD=dev-seed-password

# Log level: error | warn | info | debug
LOG_LEVEL=info
