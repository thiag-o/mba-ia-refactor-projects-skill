# Copy to .env and adjust. Never commit real secrets.

# Flask / security
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false

# Server
HOST=0.0.0.0
PORT=5000

# Database (SQLAlchemy URI). Defaults to a local SQLite file.
DATABASE_URL=sqlite:///tasks.db

# CORS: "*" to allow any origin, or a comma-separated list of origins.
CORS_ORIGINS=*

# Auth token lifetime in seconds (default 24h).
TOKEN_MAX_AGE=86400

# Email notifications (optional). If unset, email sending is skipped.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
